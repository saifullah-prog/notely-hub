# Supabase credentials — copy this file to `.env` and fill in the values from
# your Supabase dashboard → Project Settings → API.
# These are safe to expose to the browser (the anon key is public + protected by
# Row Level Security). NEVER put the service_role key here.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
